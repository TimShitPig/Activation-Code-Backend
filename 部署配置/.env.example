# Docker Compose 项目名
COMPOSE_PROJECT_NAME=activation-code-backend

# 监听地址。只想让 Nginx 反代访问时可以改成 127.0.0.1
BIND_HOST=0.0.0.0

# 宿主机访问端口
SERVER_PORT=7790

# 容器内服务端口
PORT=7790

# 时区
TZ=Asia/Shanghai

# 容器内配置文件路径，请保持默认
SYSTEM_CONFIG_PATH=/app/data/系统配置.json

# 远程 MySQL 连接
# 留空时，第一次打开网页会进入初始化向导，在网页中填写数据库信息
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=activation_system

# 管理员初始化账号
# 仅在使用 MYSQL_* 环境变量初始化时生效；网页初始化时会使用网页填写的账号密码
INIT_ADMIN_USERNAME=admin
INIT_ADMIN_PASSWORD=

# JWT 密钥
# 网页初始化时会写入 数据/系统配置.json；环境变量初始化时请填写固定随机字符串
JWT_SECRET=
JWT_EXPIRES_IN=7d

# 机器人接口调用密钥
# 留空时可在网页初始化中自动生成或手动填写
ROBOT_API_TOKEN=

# 系统更新检查
UPDATE_REPOSITORY=TimShitPig/Activation-Code-Backend
UPDATE_BRANCH=main
UPDATE_WORKDIR=/root/Activation-Code-Backend
GITHUB_TOKEN=

# 构建版本信息。服务器构建时建议设置为当前 git 提交号
# APP_COMMIT=$(git rev-parse --short HEAD) docker compose --progress plain -f docker-compose.dev.yml build
APP_VERSION=1.0.0
APP_COMMIT=unknown

# 跨域来源，多个来源用英文逗号分隔
CORS_ORIGIN=*
