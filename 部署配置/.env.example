# 服务端口
PORT=7789

# 远程 MySQL 连接
MYSQL_HOST=你的远程MySQL地址
MYSQL_PORT=3306
MYSQL_USER=你的数据库账号
MYSQL_PASSWORD=你的数据库密码
MYSQL_DATABASE=activation_system

# 管理员初始化账号
INIT_ADMIN_USERNAME=admin
INIT_ADMIN_PASSWORD=admin123456

# JWT 密钥，请生产环境替换成足够长的随机字符串
JWT_SECRET=please_change_this_secret
JWT_EXPIRES_IN=7d

# 机器人接口调用密钥
ROBOT_API_TOKEN=please_change_robot_token

# 跨域来源，多个来源用英文逗号分隔
CORS_ORIGIN=http://localhost:7788
